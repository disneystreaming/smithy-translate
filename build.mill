object `compiler-core` extends Cross[CompilerCoreModule](scalaVersions)
trait CompilerCoreModule
    extends CrossScalaModule
    with BaseScalaModule
    with BasePublishModule
    with MimaModule {

  def publishArtifactName = "smithytranslate-compiler-core"

  def baseMimaVersion = Task { Version(0, 7, 2) }

  def moduleDeps = Seq(traits)

  def mvnDeps = Seq(
    mvn"com.fasterxml.jackson.core:jackson-databind:2.20.2",
    Deps.smithyModel,
    Deps.smithyBuild,
    Deps.catsMtl,
    Deps.ciString,
    Deps.slf4j,
    Deps.alloyCore,
    Deps.collectionsCompat
  )

  object test extends BaseScalaTests with BaseMunitTests {
    def mvnDeps = super.mvnDeps() ++ Seq(Deps.smithyDiff)
  }
}

